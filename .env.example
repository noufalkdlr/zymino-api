# --- DOCKER ORCHESTRATION ---
# Defines the namespace for Docker volumes, networks, and containers.
COMPOSE_PROJECT_NAME=cashevide

# --- DJANGO CORE SETTINGS ---
SECRET_KEY=your-very-secret-key-here
DEBUG=True

# --- SECURITY SETTINGS ---
PHONE_HASH_SALT=your-phone-salt-key

ADMIN_URL=my-admin-panel

# --- COOKIE SETTINGS ---
# Comment this out for development.
# COOKIE_DOMAIN=.cashevide.com

# --- NETWORK & CORS SETTINGS ---
ALLOWED_HOSTS=api.cashevide.com,cashevide.com,46.225.234.48,192.168.31.117,127.0.0.1,localhost
CORS_ALLOWED_ORIGINS=https://app.cashevide.com,https://cashevide.com,http://localhost:8081,http://127.0.0.1:8081,http://192.168.31.117:8081
CSRF_TRUSTED_ORIGINS=https://app.cashevide.com,https://api.cashevide.com,https://cashevide.com,http://localhost:8081,http://127.0.0.1:8081,http://192.168.31.117:8081

# --- DATABASE SETTINGS ---
DB_NAME=cashevide_db
DB_USER=admin
DB_PASSWORD=strongpassword123
DB_HOST=db
DB_PORT=5432

# --- CLOUDFLARE R2 MEDIA STORAGE ---
# Set to 'True' in production to use Cloudflare R2.
USE_S3_STORAGE=False
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key
AWS_STORAGE_BUCKET_NAME=cashevide-media
AWS_S3_ENDPOINT_URL=your_url
AWS_S3_CUSTOM_DOMAIN=media.cashevide.com

# --- EMAIL (SMTP) CONFIGURATION (AWS SES)---
SMTP_USERNAME=your-SMTP-username
SMTP_PASSWORD=your-SMTP-password
DEFAULT_FROM_EMAIL=noufalkakdlr@gmail.com

# --- REDIS_URL ---
REDIS_URL=redis://redis:6379/1

# --- DJANGO SUPERUSER SETTINGS ---
DJANGO_SUPERUSER_EMAIL=noufal@email.com
DJANGO_SUPERUSER_USERNAME=noufal
DJANGO_SUPERUSER_PASSWORD=noufal
